DATABASE_URL=
NEXTAUTH_SECRET=

# ── AI / LLM Configuration ─────────────────────────────────────────────────
# Provider: local | groq | openrouter  (default: local)
LLM_PROVIDER=local
LLM_MODEL=mistral-7b-instruct-v0.3

# Local LM Studio (required for embeddings regardless of LLM_PROVIDER)
OPENAI_BASE_URL=http://localhost:1234/v1
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Groq — free tier, best for resume processing (https://console.groq.com)
GROQ_API_KEY=

# OpenRouter — free tier available (https://openrouter.ai)
OPENROUTER_API_KEY=