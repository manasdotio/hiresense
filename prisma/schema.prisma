// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  ADMIN
}

model User {
  id        String   @id @default(nanoid())
  fullname  String
  username  String   @unique
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  candidateProfile CandidateProfile?
  aiConfig         UserAIConfig?
}

model UserAIConfig {
  id        String   @id @default(nanoid())
  userId    String   @unique
  provider  String   @default("local")
  model     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateProfile {
  id              String   @id @default(nanoid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  experienceYears Float?
  resumes         Resume[]
}

model Resume {
  id          String           @id @default(nanoid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  rawText     String
  extractedAt DateTime         @default(now())

  atsScore        Float?
  atsFeedback     String?
  sectionFeedback String? // JSON blob: { skills, experience, projects, education }

  resumeSkills ResumeSkill[]
  analyses     ResumeAnalysis[]
}

model Skill {
  id        String                      @id @default(nanoid())
  name      String                      @unique
  embedding Unsupported("vector(768)")?

  resumeSkills  ResumeSkill[]
  missingSkills MissingSkill[]
}

model ResumeSkill {
  id         String @id @default(nanoid())
  resumeId   String
  skillId    String
  confidence Float?
  resume     Resume @relation(fields: [resumeId], references: [id])
  skill      Skill  @relation(fields: [skillId], references: [id])

  @@unique([resumeId, skillId])
}

model JobDescription {
  id            String   @id @default(nanoid())
  content       String
  minExperience Float?
  createdAt     DateTime @default(now())

  analyses ResumeAnalysis[]
}

model ResumeAnalysis {
  id               String   @id @default(nanoid())
  resumeId         String
  jobDescriptionId String
  score            Float
  suggestions      String?
  missingKeywords  String? // pipe-separated list
  atsIssues        String? // pipe-separated list
  skillCoverage    String? // JSON blob
  createdAt        DateTime @default(now())

  resume         Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
  missingSkills  MissingSkill[]
}

model MissingSkill {
  id         String  @id @default(nanoid())
  analysisId String
  skillId    String
  priority   String?

  analysis ResumeAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  skill    Skill          @relation(fields: [skillId], references: [id])
}
